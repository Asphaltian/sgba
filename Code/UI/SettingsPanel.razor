@namespace sGBA

@inherits PanelComponent

<root class="@(IsVisible ? "visible" : "")">
	<div class="dialog-bg" onclick=@Hide />

	<div class="dialog">
		<div class="dialog-header">
			<div class="dialog-title">#settings.title</div>
			<div class="dialog-sub">#settings.sub</div>
		</div>

		<div class="dialog-body">
			<div class="toggle-list">
				<div class="@ClassicFeelClass" onmouseenter=@(() => SelectAction(ClassicFeelAction)) onclick=@(() => ToggleClassicFeel())>
					<div class="toggle-icon">@(GamePreferences.ReproduceClassicFeel ? "check_box" : "check_box_outline_blank")</div>
					<div class="toggle-text">
						<div class="toggle-name">#settings.classicfeel</div>
						<div class="toggle-hint">#settings.classicfeel.hint</div>
					</div>
				</div>

				<div class="@SmallScreenClass" onmouseenter=@(() => SelectAction(SmallScreenAction)) onclick=@(() => ToggleSmallScreen())>
					<div class="toggle-icon">@(GamePreferences.DisplayWithSmallScreen ? "check_box" : "check_box_outline_blank")</div>
					<div class="toggle-text">
						<div class="toggle-name">#settings.smallscreen</div>
						<div class="toggle-hint">#settings.smallscreen.hint</div>
					</div>
				</div>
			</div>
		</div>

		<div class="dialog-actions">
			<div class="@BackButtonClass" onmouseenter=@(() => SelectAction(BackAction)) onclick=@(() => Hide())>#settings.back</div>
		</div>
	</div>
</root>

@code
{
	private const int ClassicFeelAction = 0;
	private const int SmallScreenAction = 1;
	private const int BackAction = 2;

	public static SettingsPanel Current { get; private set; }
	public bool IsVisible { get; private set; }

	private int _selectedIndex = ClassicFeelAction;
	private readonly GamepadFocusInput _input = new();

	private string BackButtonClass => "action-btn cancel" + (_input.UseGamepad && _selectedIndex == BackAction ? " focus" : "");
	private string ClassicFeelClass => "toggle-row" + (GamePreferences.ReproduceClassicFeel ? " selected" : "") + (_input.UseGamepad && _selectedIndex == ClassicFeelAction ? " focus" : "");
	private string SmallScreenClass => "toggle-row" + (GamePreferences.DisplayWithSmallScreen ? " selected" : "") + (_input.UseGamepad && _selectedIndex == SmallScreenAction ? " focus" : "");

	protected override void OnTreeFirstBuilt()
	{
		Current = this;
	}

	public void Show(bool useGamepad = false)
	{
		Current = this;
		IsVisible = true;
		_selectedIndex = ClassicFeelAction;
		_input.Begin(useGamepad);
		Sound.Play("ui.popup.message.open");
		StateHasChanged();
	}

	public void Hide()
	{
		IsVisible = false;
		var wasGamepad = _input.UseGamepad;
		LibraryPanel.Current?.FocusSettingsAction(wasGamepad);
		Sound.Play("ui.popup.message.close");
		StateHasChanged();
	}

	private void SelectAction(int action)
	{
		_selectedIndex = action;
	}

	private void ToggleClassicFeel(bool playSound = true)
	{
		if (playSound)
			Sound.Play("ui.button.press");

		GamePreferences.SetReproduceClassicFeel(!GamePreferences.ReproduceClassicFeel);
		StateHasChanged();
	}

	private void ToggleSmallScreen(bool playSound = true)
	{
		if (playSound)
			Sound.Play("ui.button.press");

		GamePreferences.SetDisplayWithSmallScreen(!GamePreferences.DisplayWithSmallScreen);
		StateHasChanged();
	}

	private void SetGamepadMode() => _input.ForceGamepadMode();

	protected override void OnUpdate()
	{
		if (!IsVisible)
			return;
		if (new Game.Overlay().IsOpen)
			return;

		var nav = _input.TickRepeating();
		if (nav.Up) NavigateUp();
		if (nav.Down) NavigateDown();

		if (Input.Pressed("GBA_A"))
		{
			SetGamepadMode();
			Sound.Play("ui.button.press");

			if (_selectedIndex == BackAction)
				Hide();
			else if (_selectedIndex == ClassicFeelAction)
				ToggleClassicFeel(playSound: false);
			else
				ToggleSmallScreen(playSound: false);
		}

		if (Input.Pressed("GBA_B"))
		{
			SetGamepadMode();
			Sound.Play("ui.button.press");
			Hide();
		}
	}

	private void NavigateUp()
	{
		SetGamepadMode();
		if (_selectedIndex > ClassicFeelAction)
		{
			_selectedIndex--;
			Sound.Play("ui.button.over");
		}
	}

	private void NavigateDown()
	{
		SetGamepadMode();
		if (_selectedIndex < BackAction)
		{
			_selectedIndex++;
			Sound.Play("ui.button.over");
		}
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(IsVisible, _selectedIndex, _input.UseGamepad, GamePreferences.ReproduceClassicFeel, GamePreferences.DisplayWithSmallScreen);
	}
}
