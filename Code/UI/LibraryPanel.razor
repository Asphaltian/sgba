@using Sandbox.UI
@using System.Threading.Tasks

@namespace sGBA

@inherits PanelComponent

<root class="@(IsVisible ? "visible" : "")">

	<div class="lib-bg" />

	<div class="lib-container">

		<div class="lib-header">
			<div class="lib-header-brand">
				<image src="/ui/logo.png" class="lib-logo" />
			</div>
			<div class="lib-header-right">
				<div class="lib-header-actions">
					<div class="@SearchBarClass" onmouseenter=@(() => SelectHeaderAction(HeaderSearch))>
						<div class="lib-search-icon">search</div>
						<TextEntry @ref="_searchEntry" placeholder="#library.search.placeholder" OnTextEdited=@OnSearchEdited onfocus=@OnSearchFocused onblur=@OnSearchBlurred class="lib-search-input" />
					</div>
					<div class="@SettingsButtonClass" onmouseenter=@(() => SelectHeaderAction(HeaderSettings)) onclick=@(() => OpenSettings())>
						<div class="lib-header-button-icon">settings</div>
						<div class="lib-header-button-label">#settings.button</div>
					</div>
				</div>
			</div>
		</div>

		<div class="lib-divider" />

		<div class="lib-body">

		@if (_roms.Count == 0)
		{
			<div class="lib-empty">
				<div class="lib-empty-icon">sports_esports</div>
				<div class="lib-empty-title">#library.empty.title</div>
				<div class="lib-empty-hint">#library.empty.hint</div>
			</div>
			}
			else if (_filteredRoms.Count == 0)
			{
				<div class="lib-empty">
					<div class="lib-empty-icon">search_off</div>
					<div class="lib-empty-title">#library.noresults.title</div>
					<div class="lib-empty-hint">No games match '@_searchText'</div>
				</div>
			}
			else
			{
				<RomGrid @ref="_grid" Items=@_romsAsObjects ItemSize=@(new Vector2(218, 288)) OnCellClick=@OnRomCellClick
						 ContentVersion=@_thumbnailVersion>
					<Item Context="romObj">
						@{
							var rom = (RomEntry)romObj;
						}
						@{
							_thumbnails.TryGetValue(rom.Path, out Texture thumb);
						}
						<div class="rom-card">

							<div class="card-art">

								@if (thumb != null)
								{
									<Image Texture=@thumb class="card-thumb" />
								}

								@if (thumb == null)
								{
									<div class="card-no-art">
										<div class="card-no-art-icon">question_mark</div>
									</div>
								}

								@if (!string.IsNullOrEmpty(rom.Region))
								{
									<div class="card-region-badge">@FormatRegion(rom.Region)</div>
								}

								<div class="card-launch-overlay">
									<div class="card-launch-icon">play_arrow</div>
								</div>

							</div>

							<div class="card-info">
								<div class="card-title">@rom.DisplayTitle</div>
								@if (!string.IsNullOrEmpty(rom.Publisher))
								{
									<div class="card-publisher">@rom.Publisher</div>
								}
							</div>

						</div>
					</Item>
				</RomGrid>
			}

		</div>
	</div>
</root>

@code
{
	public static LibraryPanel Current { get; private set; }

	private RomGrid _grid;
	private List<RomEntry> _roms = new();
	private List<RomEntry> _filteredRoms = new();
	private List<object> _romsAsObjects = new();
	private HashSet<string> _knownPaths = new();
	private string _searchText = "";
	private bool _searchFocused;
	private TextEntry _searchEntry;
	private float _pollTimer;
	private const float PollInterval = 3f;
	private Dictionary<string, Texture> _thumbnails = new();
	private int _thumbnailVersion;
	private int _hoveredIndex = -1;
	private bool _isVisible = true;
	private int _headerSelection = -1;

	private const float StickDeadzone = 0.1f;
	private const float RepeatDelay = 0.4f;
	private const float RepeatRate = 0.08f;
	private const int HeaderSearch = 0;
	private const int HeaderSettings = 1;

	private bool _useGamepad;
	private bool _stickUp, _stickDown, _stickLeft, _stickRight;
	private float _upHoldTime, _upNextRepeat;
	private float _downHoldTime, _downNextRepeat;
	private float _leftHoldTime, _leftNextRepeat;
	private float _rightHoldTime, _rightNextRepeat;

	private int ColumnCount => _grid?.Columns is > 0 ? _grid.Columns : Math.Max(1, (int)((Screen.Width - 96f) / (200f + 18f)));

	public bool IsVisible => _isVisible;

	protected override void OnTreeFirstBuilt()
	{
		Current = this;
		_roms = RomLibrary.Discover();
		_knownPaths = RomLibrary.GetRomPaths();
		RebuildFilteredList();
		_ = LoadThumbnailsAsync();
	}

	private async Task LoadThumbnailsAsync()
	{
		foreach (var rom in _roms.ToList())
		{
			if (string.IsNullOrEmpty(rom.ThumbnailUrl))
				continue;

			var cacheKey = string.IsNullOrEmpty(rom.GameCode)
				? Math.Abs(rom.ThumbnailUrl.GetHashCode()).ToString()
				: rom.GameCode;
			var cachePath = $"thumbnails/{cacheKey}.png";

			try
			{
				if (!FileSystem.Data.FileExists(cachePath))
				{
					var bytes = await Http.RequestBytesAsync(rom.ThumbnailUrl);
					FileSystem.Data.WriteAllBytes(cachePath, bytes);
				}

				var tex = Texture.LoadFromFileSystem(cachePath, FileSystem.Data);
				if (tex != null)
				{
					_thumbnails[rom.Path] = tex;
					_thumbnailVersion++;
					StateHasChanged();
				}
			}
			catch (Exception ex)
			{
				Log.Warning($"[sGBA] Thumbnail failed for {rom.DisplayTitle}: {ex.Message}");
			}
		}
	}

	public void Show()
	{
		EmulatorComponent.Current?.Unload();
		_isVisible = true;
		SetHovered(-1);
		_headerSelection = -1;
		_useGamepad = false;
		Mouse.Visibility = MouseVisibility.Visible;
		Sound.Play("ui.popup.message.open");
		StateHasChanged();
	}

	public void Hide()
	{
		_isVisible = false;
		Mouse.Visibility = MouseVisibility.Hidden;
		StateHasChanged();
	}

	private void OnRomCellClick(int i) => LaunchRom(_filteredRoms[i]);

	private void LaunchRom(RomEntry rom)
	{
		var emulator = EmulatorComponent.Current;
		if (!emulator.IsValid())
			return;

		Sound.Play("ui.button.press");
		Hide();
		emulator.Restart(rom.Path);
	}

	private void OnSearchFocused()
	{
		_searchFocused = true;
		_headerSelection = HeaderSearch;
	}

	private void OnSearchBlurred() => _searchFocused = false;

	private string SearchBarClass => "lib-search-bar"
		+ (_searchFocused ? " focused" : "")
		+ (_headerSelection == HeaderSearch ? " pad-hover" : "");

	private string SettingsButtonClass => "lib-header-button"
		+ (_headerSelection == HeaderSettings ? " selected" : "");

	private void RebuildFilteredList()
	{
		IEnumerable<RomEntry> result = _roms;

		var q = _searchText.Trim();
		if (!string.IsNullOrEmpty(q))
			result = result.Where(r =>
				r.DisplayTitle.Contains(q, StringComparison.OrdinalIgnoreCase) ||
				(r.Publisher ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));

		_filteredRoms = result.ToList();
		_romsAsObjects = _filteredRoms.Cast<object>().ToList();
		SetHovered(-1);
	}

	private void OnSearchEdited(string value)
	{
		_searchText = value;
		RebuildFilteredList();
	}

	private static string FormatRegion(string region)
	{
		if (region.Contains("World")) return "World";
		if (region.Contains("USA")) return "USA";
		if (region.Contains("Europe")) return "EUR";
		if (region.Contains("Japan")) return "JPN";
		if (region.Contains("Australia")) return "AUS";
		return region.Length > 10 ? region[..8] + ".." : region;
	}

	private void SetHovered(int index)
	{
		_hoveredIndex = index;
		if (_grid != null) _grid.HoveredIndex = index;
	}

	private void SetGamepadMode()
	{
		_useGamepad = true;
		if (_grid != null) _grid.UseMouseHover = false;
		Mouse.Visibility = MouseVisibility.Hidden;
	}

	private void DetectMouseUsage()
	{
		if (Mouse.Delta.Length > 5)
		{
			_useGamepad = false;
			_headerSelection = -1;
			if (_grid != null) _grid.UseMouseHover = true;
			Mouse.Visibility = MouseVisibility.Visible;
		}
	}

	private void SyncVisibilityWithEmulator()
	{
		var emu = EmulatorComponent.Current;
		bool running = emu.IsValid() && emu.IsReady && !string.IsNullOrEmpty(emu.RomPath);
		if (running && _isVisible) Hide();
		else if (!running && !_isVisible) Show();
	}

	private void SelectHeaderAction(int headerSelection)
	{
		_headerSelection = headerSelection;
		SetHovered(-1);
	}

	private SettingsPanel EnsureSettingsPanel()
	{
		if (SettingsPanel.Current != null && SettingsPanel.Current.IsValid())
			return SettingsPanel.Current;

		SettingsPanel settingsPanel = Scene.GetAllComponents<SettingsPanel>().FirstOrDefault(panel => panel.IsValid());
		if (settingsPanel != null)
			return settingsPanel;

		return AddComponent<SettingsPanel>();
	}

	private void OpenSettings(bool useGamepad = false)
	{
		if (useGamepad)
			SetGamepadMode();
		else
			Mouse.Visibility = MouseVisibility.Visible;

		_headerSelection = HeaderSettings;
		SetHovered(-1);
		Sound.Play("ui.button.press");
		SettingsPanel settingsPanel = EnsureSettingsPanel();
		settingsPanel?.Show(useGamepad);
	}

	public void FocusHeaderAction(int headerSelection, bool useGamepad)
	{
		_headerSelection = headerSelection;
		SetHovered(-1);
		_useGamepad = useGamepad;
		if (_grid != null)
			_grid.UseMouseHover = !useGamepad;
		Mouse.Visibility = useGamepad ? MouseVisibility.Hidden : MouseVisibility.Visible;
		StateHasChanged();
	}

	public void FocusSettingsAction(bool useGamepad)
	{
		FocusHeaderAction(HeaderSettings, useGamepad);
	}

	protected override void OnUpdate()
	{
		SyncVisibilityWithEmulator();

		_pollTimer += Time.Delta;
		if (_pollTimer >= PollInterval)
		{
			_pollTimer = 0f;
			var current = RomLibrary.GetRomPaths();
			if (!current.SetEquals(_knownPaths))
			{
				_knownPaths = current;
				_roms = RomLibrary.Discover();
				RebuildFilteredList();
				_ = LoadThumbnailsAsync();
				StateHasChanged();
			}
		}

		if (!_isVisible) return;
		if (SettingsPanel.Current?.IsVisible == true) return;

		DetectMouseUsage();

		if (!_useGamepad && _grid != null)
			_hoveredIndex = _grid.HoveredIndex;

		if (_searchFocused) return;

		ReadStickEdges(out var upEdge, out var downEdge, out var leftEdge, out var rightEdge);

		HandleNavRepeat("GBA_Up", upEdge, _stickUp, ref _upHoldTime, ref _upNextRepeat, () =>
		{
			SetGamepadMode(); NavigateUp();
		});
		HandleNavRepeat("GBA_Down", downEdge, _stickDown, ref _downHoldTime, ref _downNextRepeat, () =>
		{
			SetGamepadMode(); NavigateDown();
		});
		HandleNavRepeat("GBA_Left", leftEdge, _stickLeft, ref _leftHoldTime, ref _leftNextRepeat, () =>
		{
			SetGamepadMode(); NavigateLeft();
		});
		HandleNavRepeat("GBA_Right", rightEdge, _stickRight, ref _rightHoldTime, ref _rightNextRepeat, () =>
		{
			SetGamepadMode(); NavigateRight();
		});

		if (Input.Pressed("GBA_A"))
		{
			SetGamepadMode();
			if (_headerSelection == HeaderSearch)
			{
				_searchEntry?.Focus();
			}
			else if (_headerSelection == HeaderSettings)
			{
				OpenSettings(useGamepad: true);
			}
			else if (_hoveredIndex >= 0 && _filteredRoms.Count > 0)
			{
				LaunchRom(_filteredRoms[_hoveredIndex]);
			}
		}

		if (Input.Pressed("GBA_B") && _headerSelection >= 0)
		{
			SetGamepadMode();
			_headerSelection = -1;
			if (_filteredRoms.Count > 0) SetHovered(0);
			Sound.Play("ui.button.over");
		}
	}

	private void ReadStickEdges(out bool upEdge, out bool downEdge, out bool leftEdge, out bool rightEdge)
	{
		float sx = Input.GetAnalog(InputAnalog.LeftStickX);
		float sy = Input.GetAnalog(InputAnalog.LeftStickY);

		bool up = sy < -StickDeadzone;
		bool down = sy > StickDeadzone;
		bool left = sx < -StickDeadzone;
		bool right = sx > StickDeadzone;

		upEdge = up && !_stickUp;
		downEdge = down && !_stickDown;
		leftEdge = left && !_stickLeft;
		rightEdge = right && !_stickRight;

		_stickUp = up;
		_stickDown = down;
		_stickLeft = left;
		_stickRight = right;
	}

	private void HandleNavRepeat(string action, bool stickEdge, bool stickHeld,
		ref float holdTime, ref float nextRepeat, Action navigate)
	{
		if (Input.Pressed(action) || stickEdge)
		{
			holdTime = 0;
			nextRepeat = RepeatDelay;
			navigate();
		}
		else if (Input.Down(action) || stickHeld)
		{
			holdTime += Time.Delta;
			if (holdTime >= nextRepeat)
			{
				nextRepeat += RepeatRate;
				navigate();
			}
		}
		else
		{
			holdTime = 0;
		}
	}

	private void NavigateUp()
	{
		if (_headerSelection >= 0) return;
		if (_hoveredIndex < 0) { SetHovered(0); Sound.Play("ui.button.over"); return; }
		int next = _hoveredIndex - ColumnCount;
		if (next >= 0) { SetHovered(next); Sound.Play("ui.button.over"); }
		else { _headerSelection = HeaderSearch; SetHovered(-1); Sound.Play("ui.button.over"); }
	}

	private void NavigateDown()
	{
		if (_headerSelection >= 0) { _headerSelection = -1; if (_filteredRoms.Count > 0) SetHovered(0); Sound.Play("ui.button.over"); return; }
		if (_hoveredIndex < 0) { SetHovered(0); Sound.Play("ui.button.over"); return; }
		int next = _hoveredIndex + ColumnCount;
		if (next < _filteredRoms.Count) { SetHovered(next); Sound.Play("ui.button.over"); }
	}

	private void NavigateLeft()
	{
		if (_headerSelection >= 0)
		{
			if (_headerSelection > HeaderSearch)
			{
				_headerSelection--;
				Sound.Play("ui.button.over");
			}
			return;
		}
		if (_hoveredIndex < 0) { SetHovered(0); Sound.Play("ui.button.over"); return; }
		if (_hoveredIndex % ColumnCount > 0) { SetHovered(_hoveredIndex - 1); Sound.Play("ui.button.over"); }
	}

	private void NavigateRight()
	{
		if (_headerSelection >= 0)
		{
			if (_headerSelection < HeaderSettings)
			{
				_headerSelection++;
				Sound.Play("ui.button.over");
			}
			return;
		}
		if (_hoveredIndex < 0) { SetHovered(0); Sound.Play("ui.button.over"); return; }
		if (_hoveredIndex % ColumnCount < ColumnCount - 1 && _hoveredIndex + 1 < _filteredRoms.Count)
		{
			SetHovered(_hoveredIndex + 1);
			Sound.Play("ui.button.over");
		}
	}

	protected override int BuildHash()
	{
		if (_isVisible)
			return HashCode.Combine(_hoveredIndex, _filteredRoms.Count, _useGamepad, _thumbnailVersion, _searchFocused, _headerSelection);

		return HashCode.Combine(_isVisible);
	}

	protected override void OnDestroy()
	{
		if (Current == this)
			Current = null;
		_thumbnails.Clear();
	}
}
